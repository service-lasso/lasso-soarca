{
  "id": "soarca",
  "name": "SOARCA",
  "description": "Release-backed SOARCA CACAO orchestration API service.",
  "version": "1.1.0",
  "enabled": false,
  "ports": {
    "service": 8080
  },
  "portmapping": {
    "http": "${SERVICE_PORT}"
  },
  "env": {
    "PORT": "${SERVICE_PORT}",
    "GIN_MODE": "release",
    "SOARCA_ALLOWED_ORIGINS": "*",
    "MAX_EXECUTIONS": "1000",
    "MAX_REPORTERS": "5",
    "DATABASE": "false",
    "DATABASE_NAME": "soarca",
    "MONGODB_URI": "mongodb://127.0.0.1:27017",
    "DB_USERNAME": "root",
    "DB_PASSWORD": "rootpassword",
    "ENABLE_TLS": "false",
    "ENABLE_FINS": "false",
    "MQTT_BROKER": "127.0.0.1",
    "MQTT_PORT": "1883",
    "AUTH_ENABLED": "false",
    "LOG_GLOBAL_LEVEL": "info",
    "LOG_MODE": "production",
    "LOG_FORMAT": "json",
    "LOG_FILE_PATH": "${SERVICE_ROOT}/logs/soarca.log",
    "SOARCA_URL": "http://127.0.0.1:${SERVICE_PORT}"
  },
  "globalenv": {
    "SOARCA_URL": "${SOARCA_URL}",
    "SOARCA_PORT": "${SERVICE_PORT}",
    "SOARCA_SWAGGER_URL": "${SOARCA_URL}/swagger/index.html"
  },
  "urls": [
    {
      "label": "SOARCA API",
      "url": "${SOARCA_URL}",
      "kind": "local"
    },
    {
      "label": "Swagger",
      "url": "${SOARCA_URL}/swagger/index.html",
      "kind": "local"
    },
    {
      "label": "health",
      "url": "${SOARCA_URL}/status/ping",
      "kind": "local"
    }
  ],
  "artifact": {
    "kind": "archive",
    "source": {
      "type": "github-release",
      "repo": "service-lasso/lasso-soarca",
      "channel": "latest"
    },
    "platforms": {
      "win32": {
        "assetName": "lasso-soarca-1.1.0-win32.zip",
        "archiveType": "zip",
        "command": "./SOARCA.exe",
        "args": []
      },
      "linux": {
        "assetName": "lasso-soarca-1.1.0-linux.tar.gz",
        "archiveType": "tar.gz",
        "command": "./SOARCA",
        "args": []
      },
      "darwin": {
        "assetName": "lasso-soarca-1.1.0-darwin.tar.gz",
        "archiveType": "tar.gz",
        "command": "./SOARCA",
        "args": []
      }
    }
  },
  "install": {
    "files": [
      {
        "path": "./logs/.keep",
        "content": ""
      },
      {
        "path": "./runtime/.keep",
        "content": ""
      }
    ]
  },
  "healthcheck": {
    "type": "http",
    "url": "${SOARCA_URL}/status/ping",
    "expected_status": 200,
    "retries": 80,
    "interval": 250
  },
  "updates": {
    "enabled": true,
    "mode": "notify",
    "track": "latest",
    "checkIntervalSeconds": 86400
  },
  "meta": {
    "repository": {
      "type": "git",
      "url": "https://github.com/service-lasso/lasso-soarca.git"
    },
    "documentationUrl": "https://github.com/service-lasso/lasso-soarca/blob/main/README.md",
    "issuesUrl": "https://github.com/service-lasso/lasso-soarca/issues",
    "upstreamUrl": "https://github.com/COSSAS/SOARCA",
    "tags": [
      "service-lasso",
      "soarca",
      "cacao",
      "orchestration",
      "soar"
    ]
  }
}
